---
const year = new Date().getFullYear();
---

<footer class="border-t border-border/50 py-12 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <a href="/" class="font-display text-lg font-bold">
      Software <span class="text-primary">Crafting</span>
    </a>

    <div class="flex items-center gap-6 text-text-muted">
      <!-- LinkedIn -->
      <a href="https://linkedin.com/in/danieleberl" class="hover:text-primary transition-colors" aria-label="LinkedIn" target="_blank" rel="noopener">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
      </a>
    </div>

    <div class="flex flex-col md:flex-row items-center gap-4 text-text-muted text-xs font-light">
      <div class="flex gap-4">
        <a href="/portal/login" class="hover:text-text transition-colors">Kundenportal</a>
        <a href="/datenschutz" class="hover:text-text transition-colors">Datenschutz</a>
        <a href="/impressum" class="hover:text-text transition-colors">Impressum</a>
      </div>
      <p>&copy; {year} Software Crafting &middot; Inh. Daniel Eberl</p>
    </div>
  </div>
</footer>
