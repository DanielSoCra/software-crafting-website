---
import PublicLayout from '../layouts/PublicLayout.astro';
import PageHero from '../components/public/PageHero.astro';
import ScrollReveal from '../components/public/ScrollReveal.astro';
import CTASection from '../components/public/CTASection.astro';
import { services } from '../data/services';
import heroImg from '../assets/hero/hero-leistungen.jpg';

export const prerender = true;

const iconMap: Record<string, string> = {
  Globe: "M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zM2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10A15.3 15.3 0 0 1 12 2z",
  Palette: "M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10c.9 0 1.5-.7 1.5-1.5 0-.4-.1-.7-.4-1-.3-.3-.4-.6-.4-1 0-.8.7-1.5 1.5-1.5H16c3.3 0 6-2.7 6-6 0-5-4.5-9-10-9zM6.5 12a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm3-4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm5 0a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3zm3 4a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z",
  Figma: "M5 5.5A3.5 3.5 0 0 1 8.5 2H12v7H8.5A3.5 3.5 0 0 1 5 5.5zM12 2h3.5a3.5 3.5 0 1 1 0 7H12V2zM5 12a3.5 3.5 0 0 1 7 0 3.5 3.5 0 0 1-7 0zM5 18.5A3.5 3.5 0 0 1 8.5 15H12v3.5a3.5 3.5 0 1 1-7 0zM12 12a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0z",
  Search: "M11 2a9 9 0 1 0 0 18 9 9 0 0 0 0-18zM21 21l-4.35-4.35",
  Bot: "M12 8V4H8M2 14h2M20 14h2M15 13a2 2 0 0 1 0 4H9a2 2 0 0 1 0-4M6 13V8a6 6 0 0 1 12 0v5M10 16v.01M14 16v.01",
  Megaphone: "M3 11l18-5v12L3 13v-2zM11.6 16.8a3 3 0 1 1-5.8-1.6",
};
---

<PublicLayout
  title="Leistungen — Software Crafting"
  description="Webdesign, Branding, UI/UX, SEO und AI Search Optimization — handwerklich umgesetzt für Ihren digitalen Erfolg."
>
  <PageHero
    tag="Leistungen"
    title="Alles aus einer Hand. Ohne Kompromisse."
    subtitle="Ich kümmere mich um jedes Detail — damit Sie sich auf Ihr Business konzentrieren können."
    backgroundImage={heroImg}
  />

  <!-- Services Overview Grid -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Überblick</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold mb-20">Was ich für Sie tue</h2>
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-16 gap-y-14">
        {services.map((s, i) => (
          <ScrollReveal delay={i * 60}>
            <a href={`#service-${i}`} class="group block">
              <svg class="w-7 h-7 text-primary mb-4 group-hover:text-accent transition-colors duration-300" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d={iconMap[s.icon] || iconMap.Globe} />
              </svg>
              <h3 class="font-display text-lg font-semibold mb-2 group-hover:text-primary transition-colors">{s.title}</h3>
              <p class="text-text-muted font-light text-sm leading-relaxed">{s.desc}</p>
            </a>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/20" />

  <!-- Detailed Service Sections -->
  {services.map((s, i) => (
    <div>
      <section id={`service-${i}`} class="py-28 px-6">
        <div class="max-w-5xl mx-auto">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
            <ScrollReveal>
              <div>
                <svg class="w-10 h-10 text-primary mb-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={iconMap[s.icon] || iconMap.Globe} />
                </svg>
                <h2 class="font-display text-3xl font-bold mb-6">{s.title}</h2>
                <p class="text-text-muted font-light leading-relaxed">{s.detail[0]}</p>
              </div>
            </ScrollReveal>

            <ScrollReveal delay={150}>
              <div>
                <h4 class="font-display text-base font-semibold mb-5 text-text/70">Was Sie bekommen</h4>
                <ul class="space-y-3 mb-10">
                  {s.benefits.map((b) => (
                    <li class="flex items-start gap-3 text-text/80 font-light text-sm">
                      <svg class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
                      {b}
                    </li>
                  ))}
                </ul>
                {s.blogLinks.length > 0 && (
                  <div class="mt-10">
                    <h4 class="font-display text-sm font-semibold mb-4 text-text/70 flex items-center gap-2">
                      <svg class="w-4 h-4 text-primary" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                      Passende Blogartikel
                    </h4>
                    <div class="space-y-3">
                      {s.blogLinks.map((link) => (
                        <a
                          href={`/blog/${link.slug}`}
                          class="group/link flex items-center gap-3 p-3 -mx-3 rounded-lg hover:bg-bg-secondary transition-colors"
                        >
                          <span class="text-sm font-medium text-text/90 group-hover/link:text-primary transition-colors leading-snug flex-1">
                            {link.title}
                          </span>
                          <svg class="w-4 h-4 text-primary opacity-0 group-hover/link:opacity-100 transition-opacity flex-shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </ScrollReveal>
          </div>
        </div>
      </section>
      {i < services.length - 1 && <hr class="max-w-5xl mx-auto border-border/15" />}
    </div>
  ))}

  <CTASection
    heading="Bereit, Ihr Projekt zu starten?"
    subtitle="Lassen Sie uns in einem kurzen Gespräch herausfinden, wie ich Ihnen helfen kann."
    buttonText="Kostenloses Erstgespräch"
    buttonHref="/#kontakt"
  />
</PublicLayout>
