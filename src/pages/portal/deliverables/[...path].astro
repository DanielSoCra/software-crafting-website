---
export const prerender = false;

import PortalLayout from '../../../layouts/PortalLayout.astro';
import MoodBoardFeedback from '../../../components/MoodBoardFeedback.astro';
import { resolveDeliverablePath, readDeliverableFile, listDeliverableFiles, getMimeType, buildAccelRedirectPath } from '../../../lib/deliverables';
import { DELIVERABLE_TYPES, DELIVERABLE_LABELS } from '../../../lib/types';
import type { DeliverableType } from '../../../lib/types';
import { marked } from 'marked';
import sanitizeHtml from 'sanitize-html';

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase!;

// Parse path: first segment = deliverable type, rest = file path
const pathSegments = (Astro.params.path ?? '').split('/').filter(Boolean);
const deliverableType = pathSegments[0] as DeliverableType;
const filePath = pathSegments.slice(1).join('/');

// Validate deliverable type
if (!deliverableType || !DELIVERABLE_TYPES.includes(deliverableType)) {
  return new Response('Nicht gefunden', { status: 404 });
}

// Check admin impersonation
const clientParam = Astro.url.searchParams.get('client');
const { data: adminRole } = await supabase
  .from('user_roles')
  .select('role')
  .eq('user_id', user.id)
  .eq('role', 'admin')
  .single();
const isAdmin = !!adminRole;

// Get client
let clientQuery = supabase.from('clients').select('id, slug, company');
if (isAdmin && clientParam) {
  clientQuery = clientQuery.eq('slug', clientParam);
} else {
  clientQuery = clientQuery.eq('user_id', user.id);
}
const { data: client, error: clientError } = await clientQuery.single();

if (clientError && clientError.code !== 'PGRST116') {
  return new Response('Ein Fehler ist aufgetreten.', { status: 500 });
}

if (!client) {
  return new Response('Kein Zugriff', { status: 403 });
}

// Verify deliverable is published in Supabase
const { data: deliverable, error: deliverableError } = await supabase
  .from('deliverables')
  .select('*')
  .eq('client_id', client.id)
  .eq('type', deliverableType)
  .single();

if (deliverableError && deliverableError.code !== 'PGRST116') {
  return new Response('Ein Fehler ist aufgetreten.', { status: 500 });
}

if (!deliverable) {
  return new Response('Noch nicht verfügbar', { status: 404 });
}

// Mark as viewed (first visit)
if (!deliverable.viewed_at && !isAdmin) {
  await supabase
    .from('deliverables')
    .update({ viewed_at: new Date().toISOString(), status: 'viewed' })
    .eq('id', deliverable.id);
}

const slug = client.slug;
const requestedPath = filePath || '';

// Helper: render markdown safely
function renderMarkdown(mdText: string): string {
  return sanitizeHtml(marked.parse(mdText) as string, {
    allowedTags: sanitizeHtml.defaults.allowedTags.concat(['h1', 'h2', 'h3', 'img']),
    allowedAttributes: { ...sanitizeHtml.defaults.allowedAttributes, img: ['src', 'alt'] },
  });
}

// If no specific file requested, show type-root view
if (!requestedPath) {
  const metadata = deliverable.metadata as Record<string, unknown>;
  const metadataFiles = Array.isArray(metadata?.files) ? (metadata.files as string[]) : [];
  const files = metadataFiles.length > 0 ? metadataFiles : listDeliverableFiles(slug, deliverableType);

  if (deliverableType === 'brand-guide') {
    const content = readDeliverableFile(slug, 'brand-guide/brand-guide.md');
    if (!content) return new Response('Datei nicht gefunden', { status: 404 });
    Astro.locals.renderMode = 'markdown';
    Astro.locals.markdownHtml = renderMarkdown(content.toString('utf-8'));
  } else if (deliverableType === 'proposal') {
    Astro.locals.renderMode = 'pdf';
    Astro.locals.pdfPath = `/portal/deliverables/proposal/angebot.pdf${isAdmin && clientParam ? '?client=' + clientParam : ''}`;
  } else if (deliverableType === 'website-preview') {
    // Inline preview: read HTML and embed assets as data URIs to avoid auth issues in iframe
    const previewHtml = readDeliverableFile(slug, 'website-preview/index.html');
    if (!previewHtml) return new Response('Preview nicht gefunden', { status: 404 });
    let html = previewHtml.toString('utf-8');
    // Replace relative asset references with inline data URIs
    html = html.replace(/src="(assets\/[^"]+)"/g, (_match, assetPath) => {
      const assetContent = readDeliverableFile(slug, `website-preview/${assetPath}`);
      if (!assetContent) return `src="${assetPath}"`;
      const ext = assetPath.split('.').pop()?.toLowerCase();
      const mime = ext === 'png' ? 'image/png' : ext === 'jpg' || ext === 'jpeg' ? 'image/jpeg' : ext === 'svg' ? 'image/svg+xml' : ext === 'webp' ? 'image/webp' : 'application/octet-stream';
      return `src="data:${mime};base64,${assetContent.toString('base64')}"`;
    });
    Astro.locals.renderMode = 'srcdoc';
    Astro.locals.srcdocHtml = html;
  } else if (deliverableType === 'mood-board') {
    // Variant switcher like website-preview: load all variants with embedded assets
    const variants = files.filter(f => f.endsWith('.html')).sort();
    if (variants.length === 0) {
      return new Response('Keine Varianten gefunden', { status: 404 });
    }

    // Load and embed all variants
    const variantData: Record<string, string> = {};
    for (const variant of variants) {
      const variantHtml = readDeliverableFile(slug, `mood-board/${variant}`);
      if (!variantHtml) continue; // Skip variants that can't be loaded

      let html = variantHtml.toString('utf-8');

      // Helper to embed asset as data URI
      const embedAsset = (assetPath: string): string => {
        const assetContent = readDeliverableFile(slug, `mood-board/${assetPath}`);
        if (!assetContent) return assetPath;
        const ext = assetPath.split('.').pop()?.toLowerCase();
        const mime = ext === 'png' ? 'image/png' : ext === 'jpg' || ext === 'jpeg' ? 'image/jpeg' : ext === 'svg' ? 'image/svg+xml' : ext === 'webp' ? 'image/webp' : 'application/octet-stream';
        return `data:${mime};base64,${assetContent.toString('base64')}`;
      };

      // Embed src attributes
      html = html.replace(/src="(assets\/[^"]+)"/g, (_match, assetPath) => {
        return `src="${embedAsset(assetPath)}"`;
      });

      // Embed background: and background-image: URLs (both single and double quotes, with variations)
      html = html.replace(/background(?:-image)?:\s*url\(['"]?(assets\/[^'")]+)['"]?\)/g, (_match, assetPath) => {
        return `background: url('${embedAsset(assetPath)}')`;
      });

      variantData[variant.replace('.html', '')] = html;
    }

    if (Object.keys(variantData).length === 0) {
      return new Response('Keine Varianten gefunden', { status: 404 });
    }

    const firstVariantName = variants[0].replace('.html', '');

    // Check if variant was specified in URL query params (preserves selection across reloads)
    const requestedVariant = Astro.url.searchParams.get('variant');
    const activeVariantName = (requestedVariant && variantData[requestedVariant])
      ? requestedVariant
      : firstVariantName;

    Astro.locals.renderMode = 'mood-board';
    Astro.locals.variants = Object.keys(variantData);
    Astro.locals.variantData = variantData;
    Astro.locals.srcdocHtml = variantData[activeVariantName];
    Astro.locals.activeVariant = activeVariantName;

    // Load persisted feedback from Supabase
    const { data: feedbackData } = await supabase
      .from('mood_board_feedback')
      .select('*')
      .eq('deliverable_id', deliverable.id)
      .eq('client_id', client.id);
    Astro.locals.feedbackData = feedbackData || [];
  } else if (deliverableType === 'analysis') {
    Astro.locals.renderMode = 'filelist';
    Astro.locals.fileList = files.map(f => ({
      name: f,
      href: `/portal/deliverables/analysis/${f}${isAdmin && clientParam ? '?client=' + clientParam : ''}`,
    }));
  }
} else {
  // Specific file requested
  const resolvedPath = resolveDeliverablePath(slug, `${deliverableType}/${requestedPath}`);
  if (!resolvedPath) {
    return new Response('Ungültiger Pfad', { status: 403 });
  }

  const mimeType = getMimeType(requestedPath);

  if (mimeType === 'text/html') {
    const isRaw = Astro.url.searchParams.get('raw') === 'true';
    if (isRaw) {
      const content = readDeliverableFile(slug, `${deliverableType}/${requestedPath}`);
      if (!content) return new Response('Nicht gefunden', { status: 404 });
      return new Response(content, {
        headers: {
          'Content-Type': 'text/html; charset=utf-8',
          'Content-Security-Policy': "default-src 'self' 'unsafe-inline' https://cdn.tailwindcss.com; frame-ancestors 'self'",
          'X-Content-Type-Options': 'nosniff',
          'Cache-Control': 'no-store',
        },
      });
    }
    Astro.locals.renderMode = 'iframe';
    Astro.locals.iframeSrc = `/portal/deliverables/${deliverableType}/${requestedPath}?raw=true${isAdmin && clientParam ? '&client=' + clientParam : ''}`;
  } else if (mimeType === 'application/pdf') {
    const isRaw = Astro.url.searchParams.get('raw') === 'true';
    if (isRaw) {
      const content = readDeliverableFile(slug, `${deliverableType}/${requestedPath}`);
      if (!content) return new Response('Nicht gefunden', { status: 404 });
      return new Response(content, {
        headers: {
          'Content-Type': mimeType,
          'X-Content-Type-Options': 'nosniff',
        },
      });
    }
    Astro.locals.renderMode = 'pdf';
    Astro.locals.pdfPath = `/portal/deliverables/${deliverableType}/${requestedPath}?raw=true${isAdmin && clientParam ? '&client=' + clientParam : ''}`;
  } else if (mimeType === 'text/markdown') {
    const content = readDeliverableFile(slug, `${deliverableType}/${requestedPath}`);
    if (!content) return new Response('Nicht gefunden', { status: 404 });
    Astro.locals.renderMode = 'markdown';
    Astro.locals.markdownHtml = renderMarkdown(content.toString('utf-8'));
  } else {
    // Serve binary files (images, fonts, etc.) directly from disk
    const content = readDeliverableFile(slug, `${deliverableType}/${requestedPath}`);
    if (!content) return new Response('Nicht gefunden', { status: 404 });
    return new Response(content, {
      headers: {
        'Content-Type': mimeType,
        'X-Content-Type-Options': 'nosniff',
        'Cache-Control': 'public, max-age=3600',
      },
    });
  }
}

const renderMode = (Astro.locals as any).renderMode ?? 'filelist';
const markdownHtml = (Astro.locals as any).markdownHtml ?? '';
const iframeSrc = (Astro.locals as any).iframeSrc ?? '';
const srcdocHtml = (Astro.locals as any).srcdocHtml ?? '';
const pdfPath = (Astro.locals as any).pdfPath ?? '';
const fileList = (Astro.locals as any).fileList ?? [];
const title = DELIVERABLE_LABELS[deliverableType] ?? deliverableType;
---
<PortalLayout title={`${title} — ${client.company}`} email={user.email}>
  <div class="mb-4">
    <a href={`/portal/dashboard${isAdmin && clientParam ? '?client=' + clientParam : ''}`} class="text-sm text-gray-500 hover:text-gray-700">&larr; Zurück zum Dashboard</a>
  </div>
  <h1 class="text-xl font-bold mb-6">{title}</h1>

  {renderMode === 'markdown' && (
    <article class="prose prose-sm max-w-none" set:html={markdownHtml} />
  )}

  {renderMode === 'srcdoc' && (
    <div>
      <div class="flex items-center gap-2 mb-4" id="device-switcher">
        <button data-device="desktop" class="device-btn active px-3 py-1.5 text-xs rounded-md border transition-colors" title="Desktop">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8m-4-4v4"/></svg>
        </button>
        <button data-device="tablet" class="device-btn px-3 py-1.5 text-xs rounded-md border transition-colors" title="Tablet">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="4" y="2" width="16" height="20" rx="2"/><circle cx="12" cy="18" r="1"/></svg>
        </button>
        <button data-device="mobile" class="device-btn px-3 py-1.5 text-xs rounded-md border transition-colors" title="Mobile">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="18" r="1"/></svg>
        </button>
        <span class="text-xs text-gray-500 ml-2" id="device-label">Desktop</span>
      </div>
      <div class="flex justify-center transition-all duration-500 ease-out" id="preview-container">
        <iframe
          id="preview-iframe"
          srcdoc={srcdocHtml}
          sandbox="allow-scripts"
          class="border border-gray-200 rounded-lg transition-all duration-500 ease-out"
          style="width: 100%; min-height: 80vh;"
        />
      </div>
      <script>
        const sizes = {
          desktop: { width: '100%', label: 'Desktop' },
          tablet: { width: '768px', label: 'Tablet · 768px' },
          mobile: { width: '375px', label: 'Mobile · 375px' },
        };
        const iframe = document.getElementById('preview-iframe');
        const label = document.getElementById('device-label');
        const buttons = document.querySelectorAll('.device-btn');
        buttons.forEach(btn => {
          btn.addEventListener('click', () => {
            const device = btn.dataset.device;
            const size = sizes[device];
            iframe.style.width = size.width;
            label.textContent = size.label;
            buttons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
          });
        });
      </script>
      <style>
        .device-btn { color: var(--color-text-muted); border-color: var(--color-border); background: transparent; cursor: pointer; display: flex; align-items: center; }
        .device-btn:hover { color: var(--color-text); border-color: var(--color-text-muted); }
        .device-btn.active { color: var(--color-primary); border-color: var(--color-primary); background: rgba(var(--color-primary-rgb, 45,107,74), 0.1); }
      </style>
    </div>
  )}

  {renderMode === 'iframe' && (
    <iframe
      src={iframeSrc}
      sandbox="allow-scripts allow-same-origin"
      class="w-full border border-gray-200 rounded-lg"
      style="min-height: 80vh;"
    />
  )}

  {renderMode === 'pdf' && (
    <object data={pdfPath} type="application/pdf" class="w-full rounded-lg" style="min-height: 80vh;">
      <p>PDF kann nicht angezeigt werden. <a href={pdfPath} class="text-teal-600 underline">Herunterladen</a></p>
    </object>
  )}

  {renderMode === 'mood-board' && (
    <div class="space-y-8">
      <div>
        <div class="flex flex-wrap gap-2 mb-4" id="variant-switcher">
          {((Astro.locals as any).variants || []).map((variant: string) => {
            const variantName = variant.replace('.html', '');
            const isActive = variantName === (Astro.locals as any).activeVariant;
            return (
              <button
                data-variant={variantName}
                class={`px-4 py-2 rounded-lg border transition-colors font-medium text-sm ${
                  isActive
                    ? 'bg-teal-600 text-white border-teal-600'
                    : 'bg-white border-gray-200 text-gray-700 hover:border-teal-600'
                }`}
              >
                {variantName}
              </button>
            );
          })}
        </div>
        <div class="flex justify-center">
          <iframe
            id="mood-board-iframe"
            srcdoc={(Astro.locals as any).srcdocHtml}
            sandbox="allow-scripts"
            class="border border-gray-200 rounded-lg"
            style="width: 100%; min-height: 80vh;"
          />
        </div>
        <script define:vars={{ variantData: (Astro.locals as any).variantData }}>
          const buttons = document.querySelectorAll('[data-variant]');
          const iframe = document.getElementById('mood-board-iframe');

          buttons.forEach(btn => {
            btn.addEventListener('click', () => {
              const variant = btn.getAttribute('data-variant');
              const html = variantData[variant];
              if (html) {
                iframe.srcdoc = html;
                buttons.forEach(b => b.classList.remove('bg-teal-600', 'text-white', 'border-teal-600'));
                buttons.forEach(b => b.classList.add('bg-white', 'border-gray-200', 'text-gray-700'));
                btn.classList.remove('bg-white', 'border-gray-200', 'text-gray-700');
                btn.classList.add('bg-teal-600', 'text-white', 'border-teal-600');

                // Dispatch custom event so feedback component knows variant changed
                document.dispatchEvent(new CustomEvent('mood-board-variant-changed', {
                  detail: { variant }
                }));
              }
            });
          });
        </script>
      </div>
      <MoodBoardFeedback
        deliverableId={deliverable.id}
        variants={((Astro.locals as any).variants || []).map((v: string) => v.replace('.html', ''))}
        isAdmin={isAdmin}
        currentVariant={(Astro.locals as any).activeVariant || ''}
        feedbackData={(Astro.locals as any).feedbackData || []}
      />
    </div>
  )}

  {renderMode === 'filelist' && (
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {fileList.map((file: { name: string; href: string }) => (
        <a href={file.href} class="block bg-white border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
          <span class="text-sm font-medium">{file.name}</span>
        </a>
      ))}
      {fileList.length === 0 && (
        <p class="text-gray-400 text-sm col-span-2">Keine Dateien verfügbar.</p>
      )}
    </div>
  )}
</PortalLayout>
