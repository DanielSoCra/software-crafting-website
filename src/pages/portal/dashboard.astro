---
export const prerender = false;

import PortalLayout from '../../layouts/PortalLayout.astro';
import Dashboard from '../../components/portal/Dashboard';
import AdminDashboard from '../../components/portal/AdminDashboard';
import type { Deliverable, AdminClient, AdminDeliverable, AdminForm } from '../../lib/types';

const user = Astro.locals.user!;
const supabase = Astro.locals.supabase!;

// Check if user is admin
const { data: adminRole, error: adminRoleError } = await supabase
  .from('user_roles')
  .select('role')
  .eq('user_id', user.id)
  .eq('role', 'admin')
  .single();

// PGRST116 = "no rows" (not admin) — real errors should surface
if (adminRoleError && adminRoleError.code !== 'PGRST116') {
  return new Response('Ein Fehler ist aufgetreten.', { status: 500 });
}
const isAdmin = !!adminRole;
const clientParam = Astro.url.searchParams.get('client');

// Admin without ?client= → admin overview (skip client lookup entirely)
let showAdminDashboard = false;
let adminClients: AdminClient[] = [];
let adminDeliverables: AdminDeliverable[] = [];
let adminForms: AdminForm[] = [];

let client: { id: string; company: string; slug: string; metadata: Record<string, unknown> } | null = null;
let clientSlug: string | undefined;
let deliverables: Deliverable[] = [];
let latestForm: { id: string; status: string } | null = null;

if (isAdmin && !clientParam) {
  // Admin overview: fetch all data in parallel
  showAdminDashboard = true;

  const [clientsRes, deliverablesRes, formsRes] = await Promise.all([
    supabase.from('clients').select('id, company, slug, industry_key, contact_name').order('company'),
    supabase.from('deliverables').select('client_id, type, status, published_at, viewed_at'),
    supabase.from('forms').select('client_id, id, status, created_at, updated_at').order('created_at', { ascending: false }).order('id', { ascending: false }),
  ]);

  if (clientsRes.error || deliverablesRes.error || formsRes.error) {
    return new Response('Ein Fehler ist aufgetreten.', { status: 500 });
  }

  adminClients = (clientsRes.data ?? []) as AdminClient[];
  adminDeliverables = (deliverablesRes.data ?? []) as AdminDeliverable[];

  // Deduplicate forms: keep latest per client_id
  const formMap = new Map<string, AdminForm>();
  for (const form of (formsRes.data ?? []) as AdminForm[]) {
    if (!formMap.has(form.client_id)) {
      formMap.set(form.client_id, form);
    }
  }
  adminForms = Array.from(formMap.values());

} else {
  // Client view (regular user OR admin with ?client= param)
  let clientQuery = supabase.from('clients').select('id, company, slug, metadata');
  if (isAdmin && clientParam) {
    clientQuery = clientQuery.eq('slug', clientParam);
    clientSlug = clientParam;
  } else {
    clientQuery = clientQuery.eq('user_id', user.id);
  }
  const { data: clientData, error: clientError } = await clientQuery.single();

  if (clientError && clientError.code !== 'PGRST116') {
    return new Response('Ein Fehler ist aufgetreten. Bitte versuche es später erneut.', { status: 500 });
  }

  if (!clientData) {
    // Admin with bad slug → back to overview; non-admin → login
    return isAdmin
      ? Astro.redirect('/portal/dashboard')
      : Astro.redirect('/portal/login');
  }

  client = clientData;

  const [delRes, formRes] = await Promise.all([
    supabase.from('deliverables').select('*').eq('client_id', client.id),
    supabase.from('forms').select('id, status').eq('client_id', client.id).order('created_at', { ascending: false }).limit(1),
  ]);

  if (delRes.error || formRes.error) {
    return new Response('Ein Fehler ist aufgetreten. Bitte versuche es später erneut.', { status: 500 });
  }
  deliverables = (delRes.data ?? []) as Deliverable[];
  latestForm = formRes.data?.[0] ?? null;
}
---
{showAdminDashboard ? (
<PortalLayout title="Admin Dashboard" email={user.email}>
  <AdminDashboard
    clients={adminClients}
    deliverables={adminDeliverables}
    forms={adminForms}
  />
</PortalLayout>
) : (
<PortalLayout title={`Dashboard — ${client!.company}`} email={user.email}>
  <Dashboard
    company={client!.company}
    deliverables={deliverables}
    questionnaireFormId={latestForm?.id ?? null}
    questionnaireStatus={latestForm?.status ?? null}
    clientSlug={clientSlug}
    projectPlan={(client!.metadata as any)?.project_plan ?? null}
  />
</PortalLayout>
)}
