---
import PublicLayout from '../layouts/PublicLayout.astro';
import ScrollReveal from '../components/public/ScrollReveal.astro';
import ServiceCard from '../components/public/ServiceCard.astro';
import ProjectCard from '../components/public/ProjectCard.astro';
import TestimonialCard from '../components/public/TestimonialCard.astro';
import TeamCard from '../components/public/TeamCard.astro';
import CTASection from '../components/public/CTASection.astro';
import HeroSlideshow from '../components/public/HeroSlideshow.tsx';
import ContactForm from '../components/public/ContactForm.tsx';

import { services } from '../data/services';
import { projects } from '../data/projects';
import { testimonials } from '../data/testimonials';
import { processSteps } from '../data/process';
import { team } from '../data/team';

export const prerender = true;

const iconMap: Record<string, string> = {
  Globe: '🌐',
  Palette: '🎨',
  Figma: '✏️',
  Search: '🔍',
  Bot: '🤖',
  Megaphone: '📣',
};

const serviceChips = [
  { label: 'Webdesign', anchor: 'service-0' },
  { label: 'Branding', anchor: 'service-1' },
  { label: 'UI/UX', anchor: 'service-2' },
  { label: 'SEO', anchor: 'service-3' },
  { label: 'AI Search', anchor: 'service-4' },
  { label: 'Content', anchor: 'service-5' },
  { label: 'Social Media', anchor: 'service-5' },
];

const stats = [
  { value: '50+', label: 'Projekte realisiert' },
  { value: '98%', label: 'Kundenzufriedenheit' },
  { value: '12+', label: 'Jahre Erfahrung' },
  { value: '340%', label: 'Ø Reichweiten-Boost' },
];
---

<PublicLayout
  title="Software Crafting — Webdesign, Branding, SEO & AI Search Optimization"
  description="Software Crafting ist Ihre Web-Agentur für Webdesign, Branding, UI/UX, SEO und AI Search Optimization. Wir schaffen digitale Meisterwerke, die konvertieren."
>
  <!-- Hero -->
  <section class="min-h-screen flex items-center relative px-6 pt-24 pb-16">
    <div class="absolute inset-0 overflow-hidden">
      <div
        class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-20 blur-[120px]"
        style="background-color: oklch(0.55 0.2 280);"
      />
      <div
        class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full opacity-10 blur-[100px]"
        style="background-color: oklch(0.7 0.12 70);"
      />
    </div>
    <div class="relative z-10 max-w-6xl mx-auto w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <ScrollReveal>
            <p class="text-primary font-sans text-sm tracking-[0.3em] uppercase mb-6">
              Web-Agentur für digitale Exzellenz
            </p>
          </ScrollReveal>
          <ScrollReveal delay={100}>
            <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] mb-8">
              Wir schmieden<br />
              <span class="gradient-text">digitale Meisterwerke</span>
            </h1>
          </ScrollReveal>
          <ScrollReveal delay={200}>
            <div class="flex flex-wrap gap-2 mb-10">
              {serviceChips.map((chip) => (
                <a
                  href={`/leistungen#${chip.anchor}`}
                  class="px-4 py-1.5 rounded-full border border-border/60 text-sm text-text-muted font-light hover:border-primary/50 hover:text-primary transition-colors"
                >
                  {chip.label}
                </a>
              ))}
            </div>
          </ScrollReveal>
          <ScrollReveal delay={300}>
            <div class="flex flex-col sm:flex-row items-start gap-4">
              <a
                href="#kontakt"
                class="gradient-btn text-white px-8 py-3.5 rounded-full font-medium text-base inline-flex items-center gap-2"
              >
                Projekt starten
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a
                href="/leistungen"
                class="text-text-muted hover:text-text transition-colors text-base font-light py-3.5"
              >
                Unsere Leistungen entdecken &rarr;
              </a>
            </div>
          </ScrollReveal>
        </div>

        <!-- Right: Slideshow -->
        <ScrollReveal delay={200}>
          <HeroSlideshow client:load />
        </ScrollReveal>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        {stats.map((stat, i) => (
          <ScrollReveal delay={i * 100}>
            <div class="text-center">
              <p class="font-display text-4xl md:text-5xl lg:text-6xl font-bold gradient-text mb-2">
                {stat.value}
              </p>
              <p class="text-text-muted text-sm font-light">{stat.label}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Was wir tun</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-20">Unsere Leistungen</h2>
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((s, i) => (
          <ScrollReveal delay={i * 80}>
            <ServiceCard
              icon={iconMap[s.icon] ?? s.icon}
              title={s.title}
              desc={s.desc}
              href={`/leistungen#service-${i}`}
            />
          </ScrollReveal>
        ))}
      </div>
      <ScrollReveal delay={400}>
        <div class="mt-16 text-center">
          <a href="/leistungen" class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium">
            Alle Leistungen im Detail
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  <!-- Projects -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Ausgewählte Arbeiten</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-20">Referenzen</h2>
      </ScrollReveal>
      <div class="space-y-20">
        {projects.slice(0, 2).map((p) => (
          <ScrollReveal delay={100}>
            <ProjectCard
              slug={p.slug}
              title={p.title}
              category={p.category}
              desc={p.desc}
              img={p.img}
            />
          </ScrollReveal>
        ))}
      </div>
      <ScrollReveal delay={200}>
        <div class="mt-16 text-center">
          <a href="/referenzen" class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium">
            Alle Projekte ansehen
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  <!-- Testimonials -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Was unsere Kunden sagen</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-20">Kundenstimmen</h2>
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {testimonials.map((t, i) => (
          <ScrollReveal delay={i * 100}>
            <TestimonialCard
              text={t.text}
              name={t.name}
              company={t.company}
              role={t.role}
              stars={t.stars}
            />
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  <!-- Process -->
  <section class="py-32 px-6">
    <div class="max-w-3xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Wie wir arbeiten</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-20">Unser Prozess</h2>
      </ScrollReveal>
      <div class="relative">
        <div class="absolute left-[19px] top-0 bottom-0 w-px bg-border/50"></div>
        <div class="space-y-16">
          {processSteps.map((step, i) => (
            <ScrollReveal delay={i * 120}>
              <div class="relative flex gap-8 items-start">
                <div class="relative z-10 shrink-0 w-10 h-10 rounded-full border-2 border-primary/40 bg-bg flex items-center justify-center">
                  <span class="font-display text-sm font-bold text-primary">{step.num}</span>
                </div>
                <div class="pt-1">
                  <h3 class="font-display text-xl font-semibold mb-2">{step.title}</h3>
                  <p class="text-text-muted font-light text-sm leading-relaxed">{step.desc}</p>
                </div>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
      <ScrollReveal delay={400}>
        <div class="mt-16 text-center">
          <a href="/prozess" class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium">
            Mehr über unseren Prozess
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  <!-- Team -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Die Menschen dahinter</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-20">Unser Team</h2>
      </ScrollReveal>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-16">
        {team.map((m, i) => (
          <ScrollReveal delay={i * 100}>
            <TeamCard name={m.name} role={m.role} img={m.img} />
          </ScrollReveal>
        ))}
      </div>
      <ScrollReveal delay={300}>
        <div class="mt-16 text-center">
          <a href="/team" class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium">
            Das Team kennenlernen
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  <!-- Contact -->
  <section id="kontakt" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Lassen Sie uns sprechen</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">
          Bereit für Ihr <span class="gradient-text">nächstes Projekt?</span>
        </h2>
        <p class="text-text-muted font-light text-lg mb-12 leading-relaxed">
          Erzählen Sie uns von Ihrer Vision. Wir melden uns innerhalb von 24 Stunden bei Ihnen.
        </p>
      </ScrollReveal>
      <ScrollReveal delay={150}>
        <ContactForm client:load />
      </ScrollReveal>
      <ScrollReveal delay={250}>
        <div class="mt-16 flex flex-col sm:flex-row gap-8 text-text-muted text-sm font-light">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            hallo@softwarecrafting.de
          </span>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +49 30 123 456 78
          </span>
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            Berlin, Deutschland
          </span>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    heading="Starten wir Ihr Projekt"
    subtitle="Lassen Sie uns gemeinsam etwas Außergewöhnliches schaffen. Von der ersten Idee bis zum fertigen Launch — wir begleiten Sie auf dem gesamten Weg."
    buttonText="Jetzt Kontakt aufnehmen"
    buttonHref="#kontakt"
  />
</PublicLayout>
