---
import '../styles/global.css';

interface Props {
  title: string;
  email?: string;
}

const { title, email } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — Kundenportal</title>
    <meta name="supabase-url" content={import.meta.env.PUBLIC_SUPABASE_URL || ''}>
    <meta name="supabase-anon-key" content={import.meta.env.PUBLIC_SUPABASE_ANON_KEY || ''}>
    <meta name="auth-token" content={(Astro.locals as any).session?.access_token || ''}>
  </head>
  <body class="portal-page min-h-screen flex flex-col" style="background-color: var(--color-bg); color: var(--color-text); font-family: var(--font-sans);">
    <header class="border-b border-border/50 bg-bg-secondary/50 backdrop-blur-md">
      <nav class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/portal" class="font-display text-lg font-bold tracking-tight">
          Software <span class="text-primary">Crafting</span>
          <span class="text-text-muted font-sans text-sm font-light ml-2">Kundenportal</span>
        </a>
        <div class="flex items-center gap-4 text-sm font-light">
          {email && (
            <span class="text-text-muted">{email}</span>
          )}
          <a
            href="/portal/login?logout=true"
            class="text-text-muted hover:text-text transition-colors"
          >
            Abmelden
          </a>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-5xl mx-auto w-full px-6 py-10">
      <slot />
    </main>

    <footer class="border-t border-border/50 mt-auto">
      <div class="max-w-5xl mx-auto px-6 py-6 flex items-center justify-between text-xs font-light text-text-muted">
        <p>Software Crafting &middot; Inh. Daniel Eberl</p>
        <div class="flex gap-4">
          <a href="/datenschutz" class="hover:text-text transition-colors">
            Datenschutz
          </a>
          <a href="/impressum" class="hover:text-text transition-colors">
            Impressum
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
