---
import PublicLayout from '../layouts/PublicLayout.astro';
import ScrollReveal from '../components/public/ScrollReveal.astro';
import ServiceCard from '../components/public/ServiceCard.astro';
import TeamCard from '../components/public/TeamCard.astro';
import CTASection from '../components/public/CTASection.astro';
import HeroSlideshow from '../components/public/HeroSlideshow.tsx';
import ContactForm from '../components/public/ContactForm.tsx';

import { services } from '../data/services';
import { processSteps } from '../data/process';
import { team } from '../data/team';

export const prerender = true;

// Feature flags — activate when real content is available
const SHOW_STATS = false;
const SHOW_PROJECTS = false;
const SHOW_TESTIMONIALS = false;

const iconMap: Record<string, string> = {
  Globe: '🌐',
  Palette: '🎨',
  Figma: '✏️',
  Search: '🔍',
  Bot: '🤖',
  Megaphone: '📣',
};

const serviceChips = [
  { label: 'Webdesign', anchor: 'service-0' },
  { label: 'Branding', anchor: 'service-1' },
  { label: 'UI/UX', anchor: 'service-2' },
  { label: 'SEO', anchor: 'service-3' },
  { label: 'AI Search', anchor: 'service-4' },
  { label: 'Content', anchor: 'service-5' },
  { label: 'Social Media', anchor: 'service-5' },
];

// --- HIDDEN: Activate when real metrics exist ---
// const stats = [
//   { value: '50+', label: 'Projekte realisiert' },
//   { value: '98%', label: 'Kundenzufriedenheit' },
//   { value: '12+', label: 'Jahre Erfahrung' },
//   { value: '340%', label: 'Ø Reichweiten-Boost' },
// ];
---

<PublicLayout
  title="Software Crafting — Webdesign, Branding, SEO & AI Search Optimization"
  description="Webdesign, Branding, UI/UX, SEO und AI Search Optimization — handwerklich gebaut, persönlich betreut."
>
  <!-- Hero -->
  <section class="min-h-screen flex items-center relative px-6 pt-24 pb-16">
    <div class="absolute inset-0 overflow-hidden">
      <div
        class="absolute top-1/4 left-1/4 w-96 h-96 rounded-full opacity-20 blur-[120px]"
        style="background-color: oklch(0.55 0.2 280);"
      />
      <div
        class="absolute bottom-1/4 right-1/4 w-80 h-80 rounded-full opacity-10 blur-[100px]"
        style="background-color: oklch(0.7 0.12 70);"
      />
    </div>
    <div class="relative z-10 max-w-6xl mx-auto w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Left: Text -->
        <div>
          <ScrollReveal>
            <p class="text-primary font-sans text-sm tracking-[0.3em] uppercase mb-6">
              Webdesign & digitale Strategien
            </p>
          </ScrollReveal>
          <ScrollReveal delay={100}>
            <h1 class="font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.05] mb-8">
              Handwerklich<br />
              <span class="gradient-text">gebaut.</span>
            </h1>
          </ScrollReveal>
          <ScrollReveal delay={200}>
            <div class="flex flex-wrap gap-2 mb-10">
              {serviceChips.map((chip) => (
                <a
                  href={`/leistungen#${chip.anchor}`}
                  class="px-4 py-1.5 rounded-full border border-border/60 text-sm text-text-muted font-light hover:border-primary/50 hover:text-primary transition-colors"
                >
                  {chip.label}
                </a>
              ))}
            </div>
          </ScrollReveal>
          <ScrollReveal delay={300}>
            <div class="flex flex-col sm:flex-row items-start gap-4">
              <a
                href="#kontakt"
                class="gradient-btn text-white px-8 py-3.5 rounded-full font-medium text-base inline-flex items-center gap-2"
              >
                Projekt starten
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
              <a
                href="/leistungen"
                class="text-text-muted hover:text-text transition-colors text-base font-light py-3.5"
              >
                Leistungen entdecken &rarr;
              </a>
            </div>
          </ScrollReveal>
        </div>

        <!-- Right: Slideshow -->
        <ScrollReveal delay={200}>
          <HeroSlideshow client:load />
        </ScrollReveal>
      </div>
    </div>
  </section>

  {/* --- HIDDEN: Stats — activate when real metrics exist ---
  {SHOW_STATS && (
  <section class="py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12">
        {stats.map((stat, i) => (
          <ScrollReveal delay={i * 100}>
            <div class="text-center">
              <p class="font-display text-4xl md:text-5xl lg:text-6xl font-bold gradient-text mb-2">
                {stat.value}
              </p>
              <p class="text-text-muted text-sm font-light">{stat.label}</p>
            </div>
          </ScrollReveal>
        ))}
      </div>
    </div>
  </section>
  )}
  */}

  <!-- Services -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Was ich anbiete</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-20">Leistungen</h2>
      </ScrollReveal>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {services.map((s, i) => (
          <ScrollReveal delay={i * 80}>
            <ServiceCard
              icon={iconMap[s.icon] ?? s.icon}
              title={s.title}
              desc={s.desc}
              href={`/leistungen#service-${i}`}
            />
          </ScrollReveal>
        ))}
      </div>
      <ScrollReveal delay={400}>
        <div class="mt-16 text-center">
          <a href="/leistungen" class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium">
            Alle Leistungen im Detail
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  {/* --- HIDDEN: Projects — activate when real portfolio exists ---
  {SHOW_PROJECTS && (
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      ...projects section...
    </div>
  </section>
  <hr class="max-w-6xl mx-auto border-border/30" />
  )}
  */}

  {/* --- HIDDEN: Testimonials — activate when real reviews exist ---
  {SHOW_TESTIMONIALS && (
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      ...testimonials section...
    </div>
  </section>
  <hr class="max-w-6xl mx-auto border-border/30" />
  )}
  */}

  <!-- Process -->
  <section class="py-32 px-6">
    <div class="max-w-3xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Wie ich arbeite</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-20">Mein Prozess</h2>
      </ScrollReveal>
      <div class="relative">
        <div class="absolute left-[19px] top-0 bottom-0 w-px bg-border/50"></div>
        <div class="space-y-16">
          {processSteps.map((step, i) => (
            <ScrollReveal delay={i * 120}>
              <div class="relative flex gap-8 items-start">
                <div class="relative z-10 shrink-0 w-10 h-10 rounded-full border-2 border-primary/40 bg-bg flex items-center justify-center">
                  <span class="font-display text-sm font-bold text-primary">{step.num}</span>
                </div>
                <div class="pt-1">
                  <h3 class="font-display text-xl font-semibold mb-2">{step.title}</h3>
                  <p class="text-text-muted font-light text-sm leading-relaxed">{step.desc}</p>
                </div>
              </div>
            </ScrollReveal>
          ))}
        </div>
      </div>
      <ScrollReveal delay={400}>
        <div class="mt-16 text-center">
          <a href="/prozess" class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium">
            Mehr über meinen Prozess
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  <!-- About -->
  <section class="py-32 px-6">
    <div class="max-w-6xl mx-auto text-center">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Über mich</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-8">Persönliche Betreuung</h2>
      </ScrollReveal>
      <ScrollReveal delay={100}>
        <div class="flex justify-center">
          {team.map((m) => (
            <TeamCard name={m.name} role={m.role} img={m.img} />
          ))}
        </div>
      </ScrollReveal>
      <ScrollReveal delay={200}>
        <div class="mt-8 text-center">
          <a href="/team" class="inline-flex items-center gap-2 text-primary hover:text-accent transition-colors font-medium">
            Mehr erfahren
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-border/30" />

  <!-- Contact -->
  <section id="kontakt" class="py-32 px-6">
    <div class="max-w-6xl mx-auto">
      <ScrollReveal>
        <p class="text-primary text-sm tracking-[0.3em] uppercase mb-4">Schreiben Sie mir</p>
        <h2 class="font-display text-4xl md:text-5xl font-bold mb-6">
          Bereit für Ihr <span class="gradient-text">nächstes Projekt?</span>
        </h2>
        <p class="text-text-muted font-light text-lg mb-12 leading-relaxed">
          Erzählen Sie mir von Ihrer Vision. Ich melde mich innerhalb von 24 Stunden.
        </p>
      </ScrollReveal>
      <ScrollReveal delay={150}>
        <ContactForm client:load />
      </ScrollReveal>
      <ScrollReveal delay={250}>
        <div class="mt-16 flex flex-col sm:flex-row gap-8 text-text-muted text-sm font-light">
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            daniel@software-crafting.de
          </span>
        </div>
      </ScrollReveal>
    </div>
  </section>

  <!-- CTA -->
  <CTASection
    heading="Starten wir Ihr Projekt"
    subtitle="Von der ersten Idee bis zum fertigen Launch — ich begleite Sie auf dem gesamten Weg."
    buttonText="Jetzt Kontakt aufnehmen"
    buttonHref="#kontakt"
  />
</PublicLayout>
