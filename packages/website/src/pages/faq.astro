---
import PublicLayout from '../layouts/PublicLayout.astro';
import ScrollReveal from '../components/public/ScrollReveal.astro';
import CTASection from '../components/public/CTASection.astro';
import FAQAccordion from '../components/public/FAQAccordion.tsx';
import { faqs } from '../data/faqs';

export const prerender = true;

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<PublicLayout
  title="FAQ — Software Crafting"
  description="Häufig gestellte Fragen zu Leistungen, Kosten, Technologien und der Zusammenarbeit mit Software Crafting."
>
  <!-- JSON-LD FAQPage schema -->
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <!-- Text-only hero (no image) -->
  <section class="min-h-[70vh] flex items-end relative px-6">
    <div class="absolute inset-0 overflow-hidden">
      <div
        class="absolute top-1/3 left-1/4 w-80 h-80 rounded-full opacity-15 blur-[120px]"
        style="background-color: oklch(0.55 0.2 280)"
      />
    </div>
    <div class="relative z-10 max-w-4xl mx-auto pb-24 w-full">
      <ScrollReveal>
        <p class="text-primary font-sans text-sm tracking-[0.3em] uppercase mb-4">Häufige Fragen</p>
      </ScrollReveal>
      <ScrollReveal delay={100}>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-bold leading-[1.08]">
          Alles, was Sie wissen müssen.
        </h1>
      </ScrollReveal>
    </div>
  </section>

  <section class="py-20 pb-32 px-6">
    <div class="max-w-3xl mx-auto">
      <ScrollReveal delay={100}>
        <FAQAccordion client:load faqs={faqs} />
      </ScrollReveal>
    </div>
  </section>

  <CTASection
    heading="Noch Fragen?"
    subtitle="Sprechen Sie mich direkt an — ich berate Sie gerne persönlich."
    buttonText="Kostenloses Erstgespräch"
    buttonHref="/#kontakt"
  />
</PublicLayout>
